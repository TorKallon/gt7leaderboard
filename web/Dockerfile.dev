FROM node:22-alpine

WORKDIR /app

# Install dependencies first (cached layer)
COPY package.json package-lock.json ./
RUN npm ci

# Copy source
COPY . .

# Expose Next.js dev server port
EXPOSE 3000

# Push DB schema then start dev server
CMD sh -c "npx drizzle-kit push && npm run dev -- -H 0.0.0.0"
