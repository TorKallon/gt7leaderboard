# Neon PostgreSQL connection string
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Google OAuth (from Google Cloud Console)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# NextAuth
AUTH_SECRET=generate-with-openssl-rand-base64-32
AUTH_URL=https://gt7.mcnamara.io

# Ingest API authentication (shared secret with collector)
INGEST_API_KEY=your-shared-secret-here

# Restrict sign-in to a domain and/or specific emails
ALLOWED_DOMAIN=mcnamara.io
ALLOWED_EMAILS=rourkem@rourkem.com

# Discord webhook (for record notifications from API)
DISCORD_WEBHOOK_URL=

# Datadog (optional)
DD_API_KEY=
DD_SITE=datadoghq.com
